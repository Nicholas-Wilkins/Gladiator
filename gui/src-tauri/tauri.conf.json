{
  "productName": "Gladiator",
  "version": "0.1.34",
  "identifier": "com.gladiator.gui",
  "build": {
    "frontendDist": "../src",
    "beforeBuildCommand": ""
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "useLocalToolsDir": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {},
      "nsis": {}
    },
    "linux": {
      "appimage": {},
      "deb": {}
    },
    "macOS": {
      "dmg": {},
      "minimumSystemVersion": "10.15"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Gladiator",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8742 ws://127.0.0.1:8742 https://github.com https://objects.githubusercontent.com; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJCM0RFNUJDMzIxMEY1NUUKUldSZTlSQXl2T1U5S3hBZ0wraUVQS0g0dU9BVkZGQkpYY0lmTkQ1UGZFWi9ZaEhTSEU5NW14QTQK",
      "endpoints": [
        "https://github.com/Nicholas-Wilkins/Gladiator/releases/latest/download/latest.json"
      ],
      "dialog": true
    }
  }
}
